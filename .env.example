# Copy to .env and set your values.

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-random-secret-string
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (where emails will be sent)
ADMIN_EMAIL=your-email
ADMIN_PASSWORD=your-password

# Email Configuration
# The app tries Resend first, then falls back to Gmail SMTP if Resend fails.

# Resend API (primary)
# Get API key from https://resend.com/api-keys
# Use "Full Access" key if domain is not verified
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_NAME=MJ Digital Media

# Gmail SMTP (fallback)
# 1. Use your Gmail address
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
#    (requires 2FA enabled on your Google account)
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-gmail@gmail.com
SMTP_FROM_NAME=MJ Digital Media

# Stripe Configuration
# Get your API keys from https://dashboard.stripe.com/apikeys
# For BNPL (Affirm, Klarna, AfterPay), enable them in your Stripe Dashboard:
# https://dashboard.stripe.com/settings/payment_methods
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Firebase Configuration
# Get your Firebase config from https://console.firebase.google.com/project/_/settings/general
# Click "Add app" > "Web" to get these values
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456